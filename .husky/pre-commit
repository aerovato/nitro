STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | xargs -r)
if [ -n "$STAGED_FILES" ]; then
  if ! npx prettier --check --ignore-unknown $STAGED_FILES; then
    npx prettier --write --ignore-unknown $STAGED_FILES
    echo "Formatting issues detected. Please stage the formatted files."
    exit 1
  fi
fi
if ! npm run lint; then
  echo "Linting/typecheck issues detected."
  exit 1
fi
